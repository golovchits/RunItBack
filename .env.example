# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Data
DATA_ROOT=./runtime
MAX_DATA_DOWNLOAD_GB=2

# Runtime
USE_FALLBACK=false

# Managed Agents — populated by scripts/create_agents.py and scripts/create_environment.py
AGENT_ID_PAPER_ANALYST=
AGENT_ID_CODE_AUDITOR=
AGENT_ID_VALIDATOR=
AGENT_ID_REVIEWER=
MANAGED_ENVIRONMENT_ID=

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
